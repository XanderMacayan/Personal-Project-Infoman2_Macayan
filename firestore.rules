rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Library Access System - Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a robust Role-Based Access Control (RBAC) model using 
     * Database-Backed Access Control (DBAC). It distinguishes between regular users 
     * and administrators via a sentinel collection strategy.
     *
     * DATA STRUCTURE:
     * - /users/{userId}: Profiles for students and staff.
     * - /roles_admin/{userId}: A sentinel collection where the existence of a document 
     *   grants administrative privileges to the corresponding UID.
     * - /visitLogs/{visitLogId}: Flat collection of library entries, optimized for 
     *   admin dashboard queries via denormalization.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is a registered administrator via the sentinel collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the admin sentinel collection.
     */
    match /roles_admin/{userId} {
      allow get, list: if isSignedIn(); // Allow check for admin status
      allow create, update, delete: if false; // Role assignment should be manual or via cloud function for security
    }

    /**
     * @description Manages user profiles. 
     * Identification terminal requires listing to find users by email/RFID.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Terminal needs list to simulate/find users client-side
      
      allow create: if isSignedIn() && request.resource.data.id == userId;
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.isBlocked == resource.data.isBlocked);
      allow delete: if isAdmin();
    }

    /**
     * @description Records of library visits.
     */
    match /visitLogs/{visitLogId} {
      // Admins can see everything. Users can see their own logs if they have the ID.
      allow get: if isAdmin() || (isSignedIn() && resource.data.visitorId == request.auth.uid);
      
      // Only admins can list visit logs for the dashboard.
      allow list: if isAdmin();
      
      // Anyone signed in can create a log entry for themselves.
      allow create: if isSignedIn(); 
      
      allow update, delete: if isAdmin();
    }
  }
}